FLEX_DATABASE_USERNAME=flex_authenticator
FLEX_DATABASE_PASSWORD=authenticator_password
FLEX_JWT_SECRET=rqQHuW5MppUkriINN1gr1JWjftoJYWhn1234567890ohausd987ahf8a7hsf0a7shf0ash7f
